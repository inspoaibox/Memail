# ============================================================
# Memail minimal .env
# Copy to .env, then change these values.
# Gmail OAuth2, Resend, and the unified mailbox password are
# configured after startup in the Web UI gear menu.
# ============================================================

ENVIRONMENT=production

# One shared bootstrap secret. Used as the default JWT/API/session/encryption
# secret unless you override the advanced keys below.
APP_SECRET=change-me-long-random-secret

# Required Web UI admin account. You can change the username/password later
# in Web UI Settings > System Settings. Runtime settings take precedence.
ADMIN_USERNAME=admin

# Web UI login password. You can keep this bootstrap password, or set
# ADMIN_PASSWORD_HASH below and later rotate the admin password in Web UI.
ACCESS_PASSWORD=change-me-web-login-password

# First accepted mail domain. More domains can be added later in the Web UI.
DOMAINS=yourdomain.com

# Public SMTP hostname used by the SMTP server greeting / STARTTLS name.
SMTP_HOSTNAME=mail.yourdomain.com

# ============================================================
# Optional: use GitHub-built GHCR images instead of local builds.
# Replace owner and tag, then run: docker compose pull && docker compose up -d
# ============================================================
# MAIL_SERVICE_IMAGE=ghcr.io/owner/manymail-mail-service:master
# MAIL_VIEWER_IMAGE=ghcr.io/owner/manymail-mail-viewer:master
# IMAP_MAIL_IMAGE=ghcr.io/owner/manymail-imap-mail:master
# IMAP_SERVER_IMAGE=ghcr.io/owner/manymail-imap-server:master

# ============================================================
# Optional advanced overrides.
# Usually you do not need to change these for Docker Compose deployment.
# ============================================================
# JWT_SECRET=change-me-jwt-secret
# API_KEY=change-me-internal-api-key
# SECRET_KEY=change-me-flask-session-secret
# CONFIG_ENCRYPTION_KEY=change-me-runtime-settings-encryption-secret
# IMAP_ACCOUNTS_SECRET=change-me-imap-account-encryption-secret
# ADMIN_PASSWORD_HASH=scrypt:...
# SESSION_TIMEOUT_MINUTES=60
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_LOCK_MINUTES=15
# UNIFIED_PASSWORD=change-me-mailbox-password
# MONGO_URL=mongodb://mongodb:27017
# DB_NAME=mailserver
# External IMAP list/detail cache TTL. Default is 24 hours.
# IMAP_CACHE_TTL_SECONDS=86400
# IMAP_CACHE_SYNC_WINDOW=100
# IMAP_CACHE_LOOKBACK=50
# IMAP_SYNC_CHECK_INTERVAL_SECONDS=900
# IMAP_SYNC_STARTUP_DELAY_SECONDS=20
# IMAP_SYNC_SCHEDULER_ENABLED=1
# API_PORT=8080
# SMTP_PORT=25
# MESSAGE_TTL_DAYS=3
# REQUIRE_API_KEY_FOR_ACCOUNTS=1
# MAX_IMAGE_PROXY_BYTES=5242880
# IMAGE_PROXY_CONNECT_TIMEOUT_SECONDS=3
# IMAGE_PROXY_READ_TIMEOUT_SECONDS=8
# AI_TRANSLATION_TIMEOUT_SECONDS=45
# CORS_ORIGINS=https://mail.yourdomain.com
# RESEND_API_KEY=re_xxxxx
# Public site URL. OAuth callback URLs are generated by the app as:
# https://mail.yourdomain.com/imap/api/oauth/{gmail|outlook}/callback
# PUBLIC_BASE_URL=https://mail.yourdomain.com
# GOOGLE_CLIENT_ID=your-google-oauth-client-id
# GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# TLS / STARTTLS certificate paths inside the mail-service container.
# SMTP_TLS_CERT=/certs/fullchain.pem
# SMTP_TLS_KEY=/certs/privkey.pem

# IMAP server certificates for external IMAP mail clients.
# IMAP_CERTS_PATH=/etc/letsencrypt/live/mail.yourdomain.com
