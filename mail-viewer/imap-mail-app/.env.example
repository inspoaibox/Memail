# 外部 IMAP 账户持久化加密密钥（必填）
IMAP_ACCOUNTS_SECRET=random-imap-account-encryption-secret

# Gmail OAuth2（可选）
# Google Cloud Console Authorized redirect URI:
# http://localhost:3939/api/oauth/gmail/callback
# GOOGLE_CLIENT_ID=your-google-oauth-client-id
# GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:3939/api/oauth/gmail/callback

# 邮箱账户配置（可配置多个，用逗号分隔）
# 格式: 名称|IMAP服务器|端口|邮箱地址|密码

# Gmail (需要使用应用专用密码: https://myaccount.google.com/apppasswords)
# ACCOUNTS=gmail|imap.gmail.com|993|yourname@gmail.com|your-app-password

# GMX
# ACCOUNTS=gmx|imap.gmx.com|993|yourname@gmx.com|your-password

# 多个账户示例
# ACCOUNTS=gmail|imap.gmail.com|993|user@gmail.com|pass1,gmx|imap.gmx.com|993|user@gmx.com|pass2
