<Window x:Class="Memail.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Width="1580"
        Height="940"
        MinWidth="1280"
        MinHeight="760"
        Background="#E7ECF1"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="ChromeBrush" Color="#F5F7FA"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SubtlePanelBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="SelectedBrush" Color="#E7F1F3"/>
        <SolidColorBrush x:Key="SelectedStrongBrush" Color="#D7EAEE"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#CED8E2"/>
        <SolidColorBrush x:Key="TextBrush" Color="#15202B"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#647386"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1B6A78"/>
        <SolidColorBrush x:Key="UnreadBrush" Color="#235B8E"/>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Background" Value="#F7FAFC"/>
            <Setter Property="BorderBrush" Value="#B6C7D4"/>
            <Setter Property="Foreground" Value="#174D5A"/>
        </Style>
        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolButtonStyle}">
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style x:Key="PlainListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemChrome" Background="Transparent" CornerRadius="6">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#F1F6F8"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource SelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Height="50" Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Memail" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="Desktop" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="8,8,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox x:Name="AutoRefreshCheckBox" Content="自动刷新" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" Margin="0,0,10,0" Checked="AutoRefreshCheckBox_OnChanged" Unchecked="AutoRefreshCheckBox_OnChanged"/>
                    <Button x:Name="RefreshButton" Content="刷新" Style="{StaticResource ToolButtonStyle}" Click="RefreshButton_OnClick"/>
                    <Button Content="写邮件" Style="{StaticResource ToolButtonStyle}" Click="ComposeButton_OnClick"/>
                    <Button Content="设置" Style="{StaticResource ToolButtonStyle}" Click="SettingsButton_OnClick"/>
                    <Button Content="退出登录" Style="{StaticResource ToolButtonStyle}" Click="LogoutButton_OnClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Height="28" Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="12,0">
            <TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="12" TextTrimming="CharacterEllipsis"/>
        </Border>

        <Grid Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="240" MaxWidth="420"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="224" MinWidth="176" MaxWidth="320"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="398" MinWidth="310" MaxWidth="520"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="420"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="14,0">
                        <TextBlock Text="邮箱账号" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Border>
                    <ListBox Grid.Row="1"
                             x:Name="AccountsList"
                             Margin="6"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource PlainListBoxItemStyle}"
                             SelectionChanged="AccountsList_OnSelectionChanged">
                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="4,8,0,6"/>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListBox.GroupStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="9,7" Margin="0,0,0,4" CornerRadius="6" BorderBrush="#DFE6EE" BorderThickness="1" Background="#FBFCFE">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding DisplayTitle}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                        <Border x:Name="AccountUnreadBadge" Grid.Column="1" Background="#DCECEF" CornerRadius="9" Padding="7,1" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding UnreadCount}" FontSize="11" Foreground="{StaticResource PrimaryBrush}"/>
                                        </Border>
                                        <TextBlock Grid.Row="1" Text="{Binding Address}" FontSize="11" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding UnreadCount}" Value="0">
                                        <Setter TargetName="AccountUnreadBadge" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="14,0">
                        <TextBlock Text="邮箱控件" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Border>
                    <ListBox Grid.Row="1"
                             x:Name="FolderList"
                             Margin="6"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource PlainListBoxItemStyle}"
                             SelectionChanged="FolderList_OnSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" Margin="0,0,0,5" CornerRadius="6" BorderBrush="#DDE7EA" BorderThickness="1" Background="#FBFDFD">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Title}" FontSize="13" Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                        <Border x:Name="FolderCountBadge" Grid.Column="1" Background="#EDF4F6" CornerRadius="8" Padding="6,1" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding Count}" FontSize="10" Foreground="{StaticResource MutedBrush}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Count}" Value="0">
                                        <Setter TargetName="FolderCountBadge" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <Border Grid.Column="4" Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="42"/>
                    </Grid.RowDefinitions>
                    <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="14,0">
                        <TextBlock Text="邮件列表" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Border>
                    <Grid Grid.Row="1" Margin="10,7,10,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchTextBox" Height="28" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#BFD0DA" KeyDown="SearchTextBox_OnKeyDown"/>
                        <Button Grid.Column="1" x:Name="SearchButton" Content="搜索" Height="28" MinWidth="54" Margin="6,0,0,0" Click="SearchButton_OnClick"/>
                    </Grid>
                    <WrapPanel Grid.Row="2" Margin="10,1,10,3">
                        <Button x:Name="MarkPageReadButton" Content="当前页已读" Height="26" MinWidth="82" Margin="0,0,6,0" Click="MarkPageReadButton_OnClick"/>
                        <Button x:Name="MarkPageUnreadButton" Content="当前页未读" Height="26" MinWidth="82" Margin="0,0,6,0" Click="MarkPageUnreadButton_OnClick"/>
                        <Button x:Name="ListDeleteButton" Content="删除" Height="26" MinWidth="54" Click="DeleteCurrentMailButton_OnClick"/>
                    </WrapPanel>
                    <ListBox Grid.Row="3"
                             x:Name="MailList"
                             Margin="6,3,6,0"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource PlainListBoxItemStyle}"
                             SelectionChanged="MailList_OnSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="MailItemCard" Margin="0,0,0,5" Padding="9" BorderBrush="#D5DEE7" BorderThickness="1" CornerRadius="7" Background="White">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="76"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="UnreadDot" Text="●" FontSize="10" Foreground="{StaticResource UnreadBrush}" VerticalAlignment="Top" Margin="0,3,8,0"/>
                                        <StackPanel Grid.Column="1" Margin="0,0,6,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="PinnedMark" Text="置顶" FontSize="10" Foreground="#A05600" Margin="0,0,5,0" Visibility="Collapsed"/>
                                                <TextBlock x:Name="FavoriteMark" Text="收藏" FontSize="10" Foreground="#1B6A78" Margin="0,0,5,0" Visibility="Collapsed"/>
                                                <TextBlock x:Name="SenderText" Text="{Binding From}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <TextBlock x:Name="SubjectText" Text="{Binding Subject}" FontSize="13" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" MaxHeight="34"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding AccountLabel}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" TextTrimming="CharacterEllipsis" MaxWidth="120"/>
                                                <TextBlock Text="{Binding Folder}" FontSize="10" Foreground="{StaticResource MutedBrush}" Margin="8,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="90"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Intro}" FontSize="10" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Date, StringFormat={}{0:MM/dd HH:mm}}" FontSize="11" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Seen}" Value="True">
                                        <Setter TargetName="UnreadDot" Property="Visibility" Value="Hidden"/>
                                        <Setter TargetName="SenderText" Property="FontWeight" Value="Normal"/>
                                        <Setter TargetName="SubjectText" Property="FontWeight" Value="Normal"/>
                                        <Setter TargetName="MailItemCard" Property="Background" Value="#FBFCFD"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Favorite}" Value="True">
                                        <Setter TargetName="FavoriteMark" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Pinned}" Value="True">
                                        <Setter TargetName="PinnedMark" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Grid Grid.Row="4" Margin="10,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="PrevPageButton" Content="上一页" MinWidth="64" Height="28" Click="PrevPageButton_OnClick"/>
                        <TextBlock Grid.Column="1" x:Name="MailListHeaderText" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <ComboBox x:Name="PageSizeComboBox" Width="66" Height="28" SelectionChanged="PageSizeComboBox_OnSelectionChanged">
                                <ComboBoxItem Content="10"/>
                                <ComboBoxItem Content="20"/>
                                <ComboBoxItem Content="50" IsSelected="True"/>
                                <ComboBoxItem Content="100"/>
                            </ComboBox>
                            <Button x:Name="NextPageButton" Content="下一页" MinWidth="64" Height="28" Margin="6,0,0,0" Click="NextPageButton_OnClick"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="5" Width="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <Border Grid.Column="6" Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="14,0">
                        <TextBlock Text="邮件详情" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Row="1" Margin="14,10,14,8">
                        <TextBlock x:Name="MailFromText" FontSize="13" Foreground="{StaticResource TextBrush}" Margin="0,0,0,7" TextWrapping="Wrap"/>
                        <TextBlock x:Name="MailSubjectText" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,7" TextWrapping="Wrap"/>
                        <TextBlock x:Name="MailMetaText" FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                    <WrapPanel Grid.Row="2" Margin="14,0,14,8">
                        <Button x:Name="TranslateButton" Content="翻译为中文" Style="{StaticResource ToolButtonStyle}" Click="TranslateButton_OnClick"/>
                        <Button x:Name="EditDraftButton" Content="编辑草稿" Style="{StaticResource ToolButtonStyle}" Click="EditDraftButton_OnClick"/>
                        <Button x:Name="RetryOutboxButton" Content="重试发送" Style="{StaticResource ToolButtonStyle}" Click="RetryOutboxButton_OnClick"/>
                        <Button x:Name="FavoriteButton" Content="收藏" Style="{StaticResource ToolButtonStyle}" Click="FavoriteButton_OnClick"/>
                        <Button x:Name="PinButton" Content="置顶" Style="{StaticResource ToolButtonStyle}" Click="PinButton_OnClick"/>
                        <Button x:Name="ReadButton" Content="已读/未读" Style="{StaticResource ToolButtonStyle}" Click="ReadButton_OnClick"/>
                        <Button x:Name="DeleteButton" Content="删除" Style="{StaticResource ToolButtonStyle}" Click="DeleteCurrentMailButton_OnClick"/>
                        <Button x:Name="RestoreButton" Content="恢复" Style="{StaticResource ToolButtonStyle}" Click="RestoreCurrentMailButton_OnClick"/>
                        <Button x:Name="PermanentDeleteButton" Content="彻底删除" Style="{StaticResource ToolButtonStyle}" Click="PermanentDeleteCurrentMailButton_OnClick"/>
                        <Button x:Name="ReplyButton" Content="回复" Style="{StaticResource ToolButtonStyle}" Click="ReplyButton_OnClick"/>
                        <Button x:Name="ReplyAllButton" Content="回复全部" Style="{StaticResource ToolButtonStyle}" Click="ReplyAllButton_OnClick"/>
                        <Button x:Name="ForwardButton" Content="转发" Style="{StaticResource ToolButtonStyle}" Click="ForwardButton_OnClick"/>
                    </WrapPanel>
                    <Grid Grid.Row="3" Margin="10,0,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <ItemsControl x:Name="AttachmentList" Margin="0,0,0,8">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Padding="8,4" Margin="0,0,6,6" Click="AttachmentButton_OnClick" Background="#F8FBFC" BorderBrush="#C8D6DF">
                                        <TextBlock Text="{Binding Filename}" FontSize="12" Foreground="{StaticResource TextBrush}"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border Grid.Row="1" Background="#FBFCFD" BorderBrush="#E0E7EE" BorderThickness="1" CornerRadius="4">
                            <Grid>
                                <wv2:WebView2 x:Name="MailBodyWebView"/>
                                <TextBox x:Name="MailBodyFallbackText"
                                         Visibility="Collapsed"
                                         BorderThickness="0"
                                         Padding="14"
                                         Background="Transparent"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
