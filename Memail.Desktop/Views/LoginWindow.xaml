<Window x:Class="Memail.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="登录 Memail"
        Width="420"
        Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F2F5F8">
    <Border Margin="16" Background="White" CornerRadius="12" BorderBrush="#D7DEE7" BorderThickness="1">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Memail Desktop" FontSize="26" FontWeight="SemiBold" Foreground="#1D5D74" Margin="0,0,0,18"/>
            <TextBlock Grid.Row="1" Text="服务端地址" Foreground="#425163" Margin="0,0,0,6"/>
            <TextBox Grid.Row="2" x:Name="BaseUrlTextBox" Height="34" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,12"/>
            <TextBlock Grid.Row="3" Text="管理员账号" Foreground="#425163" Margin="0,0,0,6"/>
            <TextBox Grid.Row="4" x:Name="UsernameTextBox" Height="34" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,12"/>
            <StackPanel Grid.Row="5">
                <TabControl x:Name="AuthTabControl" Margin="0,0,0,12">
                    <TabItem Header="账号密码">
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="访问密码" Foreground="#425163" Margin="0,0,0,6"/>
                            <PasswordBox x:Name="PasswordBox" Height="34" Padding="10,0" Margin="0,0,0,14"/>
                            <TextBlock Text="2FA 验证码（已启用时必填）" Foreground="#425163" Margin="0,0,0,6"/>
                            <TextBox x:Name="TotpTextBox" Height="34" VerticalContentAlignment="Center" Padding="10,0"/>
                        </StackPanel>
                    </TabItem>
                    <TabItem Header="设备 Token">
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="设备 Token" Foreground="#425163" Margin="0,0,0,6"/>
                            <PasswordBox x:Name="DeviceTokenBox" Height="34" Padding="10,0" Margin="0,0,0,8"/>
                            <TextBlock Text="可在 Web 后台：设置 → 系统设置 → 设备 Token 中创建，只显示一次。" Foreground="#647386" TextWrapping="Wrap" FontSize="12"/>
                        </StackPanel>
                    </TabItem>
                </TabControl>
                <CheckBox x:Name="RememberCheckBox" Content="记住服务器和账号" IsChecked="True" Margin="0,0,0,14"/>
                <TextBlock x:Name="StatusTextBlock" Foreground="#B84A4A" Margin="0,0,0,10" TextWrapping="Wrap"/>
                <Button Height="36" Content="登录" Background="#1D5D74" Foreground="White" BorderBrush="#1D5D74" Click="OnLoginClick"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
