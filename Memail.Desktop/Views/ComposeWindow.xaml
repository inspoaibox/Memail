<Window x:Class="Memail.Desktop.Views.ComposeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="写邮件"
        Width="780"
        Height="680"
        MinWidth="680"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F5">
    <Window.Resources>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D4DCE5"/>
        <SolidColorBrush x:Key="TextBrush" Color="#15202B"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#647386"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1B6A78"/>
    </Window.Resources>
    <Border Margin="12" Background="White" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="HeaderText" Text="写邮件" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>

            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="74"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="74"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="发件人" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                <TextBlock Grid.Column="1" x:Name="FromEmailText" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
                <TextBlock Grid.Column="2" Text="显示名" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" Margin="10,0,0,0"/>
                <TextBox Grid.Column="3" x:Name="FromNameTextBox" Height="30" VerticalContentAlignment="Center" Padding="8,0"/>
            </Grid>

            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="74"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="收件人" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                <TextBox Grid.Column="1" x:Name="ToTextBox" Height="30" VerticalContentAlignment="Center" Padding="8,0"/>
            </Grid>

            <Grid Grid.Row="3" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="74"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="抄送" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                <TextBox Grid.Column="1" x:Name="CcTextBox" Height="30" VerticalContentAlignment="Center" Padding="8,0"/>
            </Grid>

            <Grid Grid.Row="4" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="74"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="密送" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                <TextBox Grid.Column="1" x:Name="BccTextBox" Height="30" VerticalContentAlignment="Center" Padding="8,0"/>
            </Grid>

            <Grid Grid.Row="5" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="74"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="主题" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                <TextBox Grid.Column="1" x:Name="SubjectTextBox" Height="30" VerticalContentAlignment="Center" Padding="8,0"/>
            </Grid>

            <TextBox Grid.Row="6"
                     x:Name="BodyTextBox"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Padding="10"
                     FontSize="14"/>

            <Grid Grid.Row="7" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <DockPanel>
                    <Button Content="添加附件" Width="86" Height="30" Margin="0,0,8,0" Click="AddAttachmentButton_OnClick"/>
                    <Button Content="清空附件" Width="86" Height="30" Margin="0,0,8,0" Click="ClearAttachmentsButton_OnClick"/>
                    <TextBlock x:Name="AttachmentSummaryTextBlock" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="StatusTextBlock" Foreground="#B84A4A" VerticalAlignment="Center" TextWrapping="Wrap" Margin="12,0,0,0"/>
                </DockPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="CancelButton" Content="取消" Width="78" Height="32" Margin="0,0,8,0" Click="CancelButton_OnClick"/>
                    <Button x:Name="SaveDraftButton" Content="保存草稿" Width="96" Height="32" Margin="0,0,8,0" Click="SaveDraftButton_OnClick"/>
                    <Button x:Name="SendButton" Content="发送" Width="88" Height="32" Background="{StaticResource PrimaryBrush}" Foreground="White" BorderBrush="{StaticResource PrimaryBrush}" Click="SendButton_OnClick"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
