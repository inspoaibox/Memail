<Window x:Class="Memail.Desktop.Views.SensitiveConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="二次确认"
        Width="380"
        Height="250"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F5">
    <Border Margin="12" Background="White" BorderBrush="#D4DCE5" BorderThickness="1" CornerRadius="8">
        <StackPanel Margin="20">
            <TextBlock x:Name="ActionTextBlock" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14"/>
            <TextBlock Text="后台登录密码" Margin="0,0,0,6"/>
            <PasswordBox x:Name="PasswordBox" Height="32" Padding="8,0" Margin="0,0,0,10"/>
            <TextBlock Text="2FA 验证码（已启用时必填）" Margin="0,0,0,6"/>
            <TextBox x:Name="TotpTextBox" Height="32" VerticalContentAlignment="Center" Padding="8,0" Margin="0,0,0,14"/>
            <TextBlock x:Name="StatusTextBlock" Foreground="#A23B3B" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Width="76" Height="30" Margin="0,0,8,0" Click="CancelButton_OnClick"/>
                <Button Content="确认" Width="84" Height="30" Background="#1B6A78" Foreground="White" BorderBrush="#1B6A78" Click="ConfirmButton_OnClick"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
