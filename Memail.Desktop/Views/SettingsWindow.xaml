<Window x:Class="Memail.Desktop.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Memail 设置"
        Width="1180"
        Height="820"
        MinWidth="980"
        MinHeight="700"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F5">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D4DCE5"/>
        <SolidColorBrush x:Key="TextBrush" Color="#15202B"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#647386"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1B6A78"/>
        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Background" Value="#F7FAFC"/>
            <Setter Property="BorderBrush" Value="#B6C7D4"/>
            <Setter Property="Foreground" Value="#174D5A"/>
        </Style>
        <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="FormPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <Border Margin="12" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8">
        <DockPanel>
            <Border DockPanel.Dock="Top" Height="54" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="18,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="设置" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="刷新" Style="{StaticResource ToolButtonStyle}" Click="RefreshButton_OnClick"/>
                </Grid>
            </Border>

            <Grid Margin="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*"/>
                    <ColumnDefinition Width="1.15*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,14,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="320"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="账号设置" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,10"/>
                    <ListBox Grid.Row="1" x:Name="AccountListBox" BorderBrush="{StaticResource BorderBrushSoft}" SelectionChanged="AccountListBox_OnSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="9" Margin="0,0,0,4" BorderBrush="#E0E7EE" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayTitle}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock Text="{Binding Address}" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                            <TextBlock Text="{Binding GroupLabel}" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Type}" FontSize="11" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ScrollViewer Grid.Row="2" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="本地邮箱" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBlock Text="邮箱地址" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                            <TextBox x:Name="LocalAddressTextBox" Style="{StaticResource FormTextBoxStyle}" Tag="邮箱地址"/>
                            <TextBlock Text="显示名 / 备注" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                            <TextBox x:Name="LocalDisplayNameTextBox" Style="{StaticResource FormTextBoxStyle}"/>
                            <TextBlock Text="发件显示名" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                            <TextBox x:Name="LocalSendNameTextBox" Style="{StaticResource FormTextBoxStyle}"/>
                            <TextBlock Text="分组" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                            <TextBox x:Name="LocalGroupTextBox" Style="{StaticResource FormTextBoxStyle}"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="新增/保存本地" Style="{StaticResource ToolButtonStyle}" Click="SaveLocalButton_OnClick"/>
                                <Button Content="删除本地" Style="{StaticResource ToolButtonStyle}" Click="DeleteLocalButton_OnClick"/>
                            </StackPanel>
                            <TextBlock Text="输入顺序：邮箱地址、显示名、发件名、分组" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="外部 IMAP/SMTP" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBlock Text="邮箱类型" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                            <ComboBox x:Name="ExternalPresetComboBox" Height="30" Margin="0,0,0,8" SelectionChanged="ExternalPresetComboBox_OnSelectionChanged">
                                <ComboBoxItem Content="auto" IsSelected="True"/>
                                <ComboBoxItem Content="gmail"/>
                                <ComboBoxItem Content="outlook"/>
                                <ComboBoxItem Content="qq"/>
                                <ComboBoxItem Content="163"/>
                                <ComboBoxItem Content="mxroute"/>
                                <ComboBoxItem Content="custom"/>
                            </ComboBox>
                            <TextBlock Text="邮箱地址" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                            <TextBox x:Name="ExternalEmailTextBox" Style="{StaticResource FormTextBoxStyle}"/>
                            <TextBlock Text="密码 / 授权码" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                            <PasswordBox x:Name="ExternalPasswordBox" Style="{StaticResource FormPasswordBoxStyle}"/>
                            <TextBlock Text="显示名 / 备注" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                            <TextBox x:Name="ExternalDisplayNameTextBox" Style="{StaticResource FormTextBoxStyle}"/>
                            <TextBlock Text="发件显示名" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                            <TextBox x:Name="ExternalSendNameTextBox" Style="{StaticResource FormTextBoxStyle}"/>
                            <TextBlock Text="分组" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                            <TextBox x:Name="ExternalGroupTextBox" Style="{StaticResource FormTextBoxStyle}"/>
                            <TextBlock Text="IMAP 主机 / 端口" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="68"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ExternalHostTextBox" Style="{StaticResource FormTextBoxStyle}"/>
                                <TextBox Grid.Column="1" x:Name="ExternalPortTextBox" Style="{StaticResource FormTextBoxStyle}" Margin="6,0,0,8"/>
                            </Grid>
                            <TextBlock Text="SMTP 主机 / 端口" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="68"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ExternalSmtpHostTextBox" Style="{StaticResource FormTextBoxStyle}"/>
                                <TextBox Grid.Column="1" x:Name="ExternalSmtpPortTextBox" Style="{StaticResource FormTextBoxStyle}" Margin="6,0,0,8"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="新增/保存外部" Style="{StaticResource ToolButtonStyle}" Click="SaveExternalButton_OnClick"/>
                                <Button Content="删除外部" Style="{StaticResource ToolButtonStyle}" Click="DeleteExternalButton_OnClick"/>
                            </StackPanel>
                            <TextBlock Text="密码为空时，编辑外部账号会沿用原密码；自定义/MXRoute 可填写 IMAP/SMTP 主机和端口。" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                    </ScrollViewer>
                </Grid>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TabControl>
                        <TabItem Header="AI 设置">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="2*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ListBox x:Name="AiChannelListBox" BorderBrush="{StaticResource BorderBrushSoft}" SelectionChanged="AiChannelListBox_OnSelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="9" Margin="0,0,0,4" BorderBrush="#E0E7EE" BorderThickness="0,0,0,1">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding BaseUrl}" FontSize="11" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Grid Grid.Row="1" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="新增渠道" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <TextBlock Text="渠道名称" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                        <TextBox x:Name="AiNameTextBox" Style="{StaticResource FormTextBoxStyle}"/>
                                        <TextBlock Text="渠道类型" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                        <ComboBox x:Name="AiProviderComboBox" Height="30" Margin="0,0,0,8">
                                            <ComboBoxItem Content="openai"/>
                                            <ComboBoxItem Content="gemini"/>
                                            <ComboBoxItem Content="openai_compatible" IsSelected="True"/>
                                        </ComboBox>
                                        <TextBlock Text="Base URL" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                        <TextBox x:Name="AiBaseUrlTextBox" Style="{StaticResource FormTextBoxStyle}"/>
                                        <TextBlock Text="API Key" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                        <PasswordBox x:Name="AiApiKeyPasswordBox" Style="{StaticResource FormPasswordBoxStyle}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="拉取模型并新增" Style="{StaticResource ToolButtonStyle}" Click="AddAiChannelButton_OnClick"/>
                                            <Button Content="删除渠道" Style="{StaticResource ToolButtonStyle}" Click="DeleteAiChannelButton_OnClick"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="默认模型" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <ComboBox x:Name="AiDefaultChannelComboBox" Height="30" Margin="0,0,0,8" SelectionChanged="AiDefaultChannelComboBox_OnSelectionChanged"/>
                                        <ComboBox x:Name="AiDefaultModelComboBox" Height="30" Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="保存默认模型" Style="{StaticResource ToolButtonStyle}" Click="SaveAiDefaultButton_OnClick"/>
                                            <Button Content="刷新模型" Style="{StaticResource ToolButtonStyle}" Click="RefreshAiModelsButton_OnClick"/>
                                        </StackPanel>
                                        <TextBlock Text="翻译功能会调用这里保存的默认模型。" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </TabItem>
                        <TabItem Header="安全中心">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="1.1*"/>
                                    <RowDefinition Height="1*"/>
                                    <RowDefinition Height="1*"/>
                                </Grid.RowDefinitions>
                                <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="二次验证 / TOTP" FontWeight="SemiBold"/>
                                            <TextBlock x:Name="TotpStatusTextBlock" Text="正在读取..." Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,4,0,0"/>
                                            <TextBox x:Name="TotpSecretTextBox" Height="28" IsReadOnly="True" Margin="0,8,0,0" Padding="8,0" VerticalContentAlignment="Center"/>
                                            <TextBox x:Name="TotpCodeTextBox" Height="28" Width="160" HorizontalAlignment="Left" Margin="0,8,0,0" Padding="8,0" VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Vertical" Margin="12,0,0,0">
                                            <Button Content="生成密钥" Style="{StaticResource ToolButtonStyle}" Margin="0,0,0,6" Click="SetupTotpButton_OnClick"/>
                                            <Button Content="启用 2FA" Style="{StaticResource ToolButtonStyle}" Margin="0,0,0,6" Click="EnableTotpButton_OnClick"/>
                                            <Button Content="关闭 2FA" Style="{StaticResource ToolButtonStyle}" Margin="0" Click="DisableTotpButton_OnClick"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="登录会话" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ListBox Grid.Row="1" x:Name="SecuritySessionListBox" BorderBrush="{StaticResource BorderBrushSoft}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="6,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="12"/>
                                                            <TextBlock Text="{Binding Summary}" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding DisplayStatus}" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,8,0"/>
                                                            <Button Content="踢出" Height="24" Padding="8,0" Click="RevokeSessionButton_OnClick"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>
                                <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="设备 Token" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBox x:Name="DeviceTokenNameTextBox" Width="180" Height="28" Padding="8,0" VerticalContentAlignment="Center" Margin="8,0,6,0" Text="Memail Desktop"/>
                                                <Button Content="创建 Token" Style="{StaticResource ToolButtonStyle}" Click="CreateDeviceTokenButton_OnClick"/>
                                            </StackPanel>
                                        </Grid>
                                        <ListBox Grid.Row="1" x:Name="DeviceTokenListBox" Margin="0,10,0,0" BorderBrush="{StaticResource BorderBrushSoft}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="6,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"/>
                                                            <TextBlock Text="{Binding SeenSummary}" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding DisplayStatus}" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,8,0"/>
                                                            <Button Content="撤销" Height="24" Padding="8,0" Click="RevokeDeviceTokenButton_OnClick"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>
                                <Border Grid.Row="3" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="6" Padding="10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="审计日志" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ListBox Grid.Row="1" x:Name="AuditLogListBox" BorderBrush="{StaticResource BorderBrushSoft}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="6,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Action}" FontWeight="SemiBold" FontSize="12"/>
                                                            <TextBlock Text="{Binding Summary}" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" Text="{Binding DisplayStatus}" Foreground="{StaticResource MutedBrush}" FontSize="11" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>
                        <TabItem Header="关键词规则">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1.1*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ListBox x:Name="KeywordRuleListBox" BorderBrush="{StaticResource BorderBrushSoft}" SelectionChanged="KeywordRuleListBox_OnSelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="9" Margin="0,0,0,4" BorderBrush="#E0E7EE" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Summary}" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                                        <TextBlock Text="{Binding KeywordText}" FontSize="11" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayStatus}" FontSize="11" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Grid Grid.Row="1" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="规则名称" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                        <TextBox x:Name="KeywordRuleNameTextBox" Style="{StaticResource FormTextBoxStyle}"/>
                                        <TextBlock Text="关键词" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                        <TextBox x:Name="KeywordRuleKeywordsTextBox" Height="78" TextWrapping="Wrap" AcceptsReturn="True" Padding="8" Margin="0,0,0,8"/>
                                        <TextBlock Text="匹配字段" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                        <TextBox x:Name="KeywordRuleFieldsTextBox" Style="{StaticResource FormTextBoxStyle}" Text="subject,from,intro"/>
                                        <CheckBox x:Name="KeywordRuleEnabledCheckBox" Content="启用规则" IsChecked="True" Margin="0,2,0,8"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBox x:Name="KeywordRuleIdTextBox" Visibility="Collapsed"/>
                                        <TextBlock Text="匹配方式" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                        <ComboBox x:Name="KeywordMatchModeComboBox" Height="30" Margin="0,0,0,8">
                                            <ComboBoxItem Content="any" IsSelected="True"/>
                                            <ComboBoxItem Content="all"/>
                                        </ComboBox>
                                        <TextBlock Text="监控范围" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                        <ComboBox x:Name="KeywordScopeComboBox" Height="30" Margin="0,0,0,8">
                                            <ComboBoxItem Content="all" IsSelected="True"/>
                                            <ComboBoxItem Content="group"/>
                                            <ComboBoxItem Content="accounts"/>
                                        </ComboBox>
                                        <TextBlock Text="分组名（范围为 group 时）" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                        <TextBox x:Name="KeywordRuleGroupTextBox" Style="{StaticResource FormTextBoxStyle}"/>
                                        <TextBlock Text="账号 Key（范围为 accounts 时，逗号分隔：local:邮箱 或 external:id）" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                        <TextBox x:Name="KeywordRuleAccountsTextBox" Style="{StaticResource FormTextBoxStyle}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="保存规则" Style="{StaticResource ToolButtonStyle}" Click="SaveKeywordRuleButton_OnClick"/>
                                            <Button Content="删除规则" Style="{StaticResource ToolButtonStyle}" Click="DeleteKeywordRuleButton_OnClick"/>
                                            <Button Content="重置" Style="{StaticResource ToolButtonStyle}" Click="ResetKeywordRuleButton_OnClick"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                    <TextBlock Grid.Row="1" x:Name="StatusTextBlock" Foreground="#A23B3B" Margin="0,12,0,0" TextWrapping="Wrap"/>
                </Grid>
            </Grid>
        </DockPanel>
    </Border>
</Window>
